# ─── PrepVerse frontend env (copy to .env) ───────────────────────────
# These are baked into the static build. The ANON key is PUBLIC and safe
# to ship — every table is protected by Row-Level Security.
# Find both in Supabase → Project Settings → API.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# NOTE: the SERVICE ROLE key is NOT used by the frontend and must never
# go here. It is only used by scripts/seed-supabase.mjs via shell env.
